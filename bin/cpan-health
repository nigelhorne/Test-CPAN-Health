#!/usr/bin/env perl

use strict;
use warnings;
use autodie qw(:all);

use Carp qw(croak);
use Getopt::Long qw(:config no_auto_abbrev bundling);
use Pod::Usage;
use Scalar::Util qw(looks_like_number);

our $VERSION = '0.01';

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

my %opts = (
	format    => 'terminal',
	severity  => 3,
	min_score => 0,
);

GetOptions(
	\%opts,
	'format|f=s',
	'check=s@',
	'skip=s@',
	'severity=i',
	'no-network|no_network',
	'no-cover|no_cover',
	'cache-dir|cache_dir=s',
	'output|o=s',
	'min-score|min_score=i',
	'verbose|v',
	'help|h',
	'version|V',
) or pod2usage(2);

pod2usage(0) if $opts{help};

if ($opts{version}) {
	print "cpan-health $VERSION\n";
	exit 0;
}

pod2usage({ -message => 'A distribution path or name is required.', -exitval => 2 })
	unless @ARGV;

my $target = shift @ARGV;

# Validate --format early to give a useful error before doing any work.
my %VALID_FORMATS = map { $_ => 1 } qw(terminal json html tap);
unless ($VALID_FORMATS{ lc $opts{format} }) {
	die "Unknown format '$opts{format}'. Valid formats: " . join(', ', sort keys %VALID_FORMATS) . "\n";
}

# ---------------------------------------------------------------------------
# Construct and run
# ---------------------------------------------------------------------------

require Test::CPAN::Health;

# Decide whether $target is a local path, a dist name (Foo-Bar), or a module
# name (Foo::Bar).  Heuristic: presence of '/' or an existing directory => path.
my %target_arg;
if (-e $target) {
	$target_arg{path} = $target;
} elsif ($target =~ /::/) {
	$target_arg{module} = $target;
} else {
	$target_arg{dist} = $target;
}

my $health = Test::CPAN::Health->new(
	%target_arg,
	format     => lc $opts{format},
	no_network => $opts{'no-network'} // 0,
	no_cover   => $opts{'no-cover'}   // 0,
	severity   => $opts{severity},
	min_score  => $opts{min_score},
	$opts{'cache-dir'} ? (cache_dir => $opts{'cache-dir'}) : (),
	$opts{check}       ? (checks    => $opts{check})       : (),
	$opts{skip}        ? (skip      => $opts{skip})        : (),
);

my $report   = $health->analyse;
my $rendered = $health->report_to($report);

# Write to file or STDOUT
if ($opts{output}) {
	open my $fh, '>', $opts{output};
	print {$fh} $rendered;
	close $fh;
	print "Report written to $opts{output}\n" if $opts{format} ne 'tap';
} else {
	print $rendered;
	print "\n" unless $rendered =~ /\n$/;
}

# Exit non-zero when score is below the requested threshold.
# This enables use in CI: cpan-health --min-score=80 My-Dist && echo "OK"
my $score = $report->overall_score;
exit 1 if $score < $opts{min_score};
exit 0;

# ---------------------------------------------------------------------------

__END__

=head1 NAME

cpan-health - Analyse a CPAN distribution and produce a health report

=head1 SYNOPSIS

    cpan-health [options] <dist-or-path>

      dist-or-path   CPAN dist name (Foo-Bar), Perl module name (Foo::Bar),
                     or local filesystem path to an unpacked distribution.

    Options:
      -f, --format=terminal|json|html|tap   Output format (default: terminal)
      --check=NAME[,NAME]                   Run only these checks (repeatable)
      --skip=NAME[,NAME]                    Skip these checks (repeatable)
      --severity=1-5                        Perl::Critic severity (default: 3)
      --no-network                          Skip all network-dependent checks
      --no-cover                            Skip Devel::Cover (slow)
      --cache-dir=DIR                       Override cache directory
      -o, --output=FILE                     Write report to file
      --min-score=N                         Exit 1 if overall score < N
      -v, --verbose                         Show details for passing checks too
      -h, --help                            Show this help
      -V, --version                         Show version

=head1 DESCRIPTION

C<cpan-health> is the command-line interface to L<Test::CPAN::Health>.  It
runs a configurable battery of checks (POD coverage, CPAN Testers pass rate,
kwalitee, CI configuration, META validity, SPDX license, stale and abandoned
dependencies, known CVEs, reverse dependencies, documentation quality,
examples, benchmarks, semantic versioning, perlcritic violations, code
complexity, duplicate code, test coverage, minimum Perl version, and
deprecation warnings) and reports a weighted score out of 100.

=head1 EXAMPLES

    # Analyse a local distribution checkout
    cpan-health .

    # Analyse by CPAN dist name, output JSON
    cpan-health --format=json LWP-UserAgent

    # Fail CI if score drops below 80
    cpan-health --min-score=80 My-Dist

    # TAP output -- pipe into prove
    cpan-health --format=tap My-Dist | prove --stdin

    # Skip slow checks, show verbose output
    cpan-health --no-cover --verbose My-Module

=head1 EXIT CODES

=over 4

=item 0 -- All checks completed and overall score >= --min-score (or no threshold set).

=item 1 -- Overall score is below --min-score, or a fatal error occurred.

=item 2 -- Invalid arguments.

=back

